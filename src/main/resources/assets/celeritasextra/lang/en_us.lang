# Render Options
celeritasextra.option.render.fog=Fog
celeritasextra.option.render.fog.tooltip=If enabled, fog will be rendered.
celeritasextra.option.render.fog_start=Fog Start Multiplier
celeritasextra.option.render.fog_start.tooltip=Adjusts when the terrain fog begins to render for the player.
celeritasextra.option.render.fog_distance=Fog Distance
celeritasextra.option.render.fog_distance.tooltip=Controls the fog render distance in chunks. 0 = Default (uses render distance).
celeritasextra.option.render.fog_type=Fog Type
celeritasextra.option.render.fog_type.tooltip=Controls how fog is applied. Default applies normal fog, Off disables fog rendering.
celeritasextra.option.fog_type.default=Default
celeritasextra.option.fog_type.off=Off
celeritasextra.option.render.prevent_shaders=Prevent Shaders
celeritasextra.option.render.prevent_shaders.tooltip=If enabled, any type of vanilla shaders will be prevented from loading. For example, the distorted view when spectating from a spider's point of view.
celeritasextra.option.render.clouds=Clouds
celeritasextra.option.render.clouds.tooltip=If enabled, clouds are rendered.
celeritasextra.option.render.cloud_height=Cloud Height
celeritasextra.option.render.cloud_height.tooltip=Controls the height of clouds that are rendered.
celeritasextra.option.render.light_updates=Light Updates
celeritasextra.option.render.light_updates.tooltip=If disabled, light updates will not be processed. This can improve performance but may cause visual artifacts.
celeritasextra.option.render.item_frames=Item Frames
celeritasextra.option.render.item_frames.tooltip=If enabled, item frames are rendered.
celeritasextra.option.render.armor_stands=Armor Stands
celeritasextra.option.render.armor_stands.tooltip=If enabled, armor stands are rendered.
celeritasextra.option.render.paintings=Paintings
celeritasextra.option.render.paintings.tooltip=If enabled, paintings are rendered.
celeritasextra.option.render.pistons=Pistons
celeritasextra.option.render.pistons.tooltip=If enabled, piston extending animations are rendered.
celeritasextra.option.render.beacons=Beacon Beam
celeritasextra.option.render.beacons.tooltip=If enabled, beacon beams are rendered.
celeritasextra.option.render.limit_beacon_beam_height=Limit Beacon Beam Height
celeritasextra.option.render.limit_beacon_beam_height.tooltip=If enabled, beacon beams will be limited to the maximum height of the world.
celeritasextra.option.render.enchanting_books=Enchanting Table Book
celeritasextra.option.render.enchanting_books.tooltip=If enabled, enchanting table books are rendered.
celeritasextra.option.render.player_name_tag=Player Name Tag
celeritasextra.option.render.player_name_tag.tooltip=If enabled, player name tags will be visible.
celeritasextra.option.render.item_frame_name_tag=Item Frame Name Tag
celeritasextra.option.render.item_frame_name_tag.tooltip=If enabled, item frame name tags will be visible.

# Extra Options
celeritasextra.option.extra.fps=Show FPS
celeritasextra.option.extra.fps.tooltip=Displays the current FPS of the game on the overlay.
celeritasextra.option.extra.fps_extended=Show FPS Extended
celeritasextra.option.extra.fps_extended.tooltip=Displays additional information (average, 1%% low, and 0.1%% low FPS) alongside current FPS on the overlay.
celeritasextra.option.extra.coords=Show Coordinates
celeritasextra.option.extra.coords.tooltip=Displays player coordinates on the overlay.
celeritasextra.option.extra.ignore_reduced_debug_info=Ignore Reduced Debug Info
celeritasextra.option.extra.ignore_reduced_debug_info.tooltip=If enabled, coordinates will be shown even when reduced debug info is active (e.g., on servers with reducedDebugInfo gamerule).
celeritasextra.option.extra.overlay_corner=Overlay Corner
celeritasextra.option.extra.overlay_corner.tooltip=Determines which corner of the screen the overlay (FPS and Coordinates) will be rendered.
celeritasextra.option.extra.text_contrast=Text Contrast
celeritasextra.option.extra.text_contrast.tooltip=Adjusts the contrast of the FPS/Coordinates counter.\n- None: Default plain white text\n- Background: Renders a background to the text like the debug menu\n- Shadow: Plain white text with shadow
celeritasextra.option.extra.vertical_sync=VSync
celeritasextra.option.extra.vertical_sync.tooltip=Controls vertical synchronization mode.\n- Off: VSync disabled, may cause screen tearing\n- On: Standard VSync, limits FPS to refresh rate\n- Adaptive: Enables VSync when above refresh rate, disables when below to reduce stuttering. Only available if supported by GPU driver.
celeritasextra.option.extra.reduced_motion=Reduced Motion
celeritasextra.option.extra.reduced_motion.tooltip=Reduce motion effects for accessibility.
celeritasextra.option.extra.steady_debug_hud=Steady Debug Hud
celeritasextra.option.extra.steady_debug_hud.tooltip=If enabled, the debug hud will be refreshed at a certain amount of ticks configured by the Steady Debug Hud Refresh Rate.
celeritasextra.option.extra.steady_debug_hud_refresh=Steady Debug Hud Refresh Interval
celeritasextra.option.extra.steady_debug_hud_refresh.tooltip=Adjusts the interval of when the debug hud will be refreshed in ticks.

